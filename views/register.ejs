<h1>Recruiter Registration form</h1>

<% if(errors && errors.length>0){ %>
    <ul>
        <% errors.forEach((error) => { %>
            <li><%= error.msg %></li>
        <% }) %>
    </ul>
<% } %>

<form action="/register" method="post">

    <div>
        <label>Name</label>
        <input type="text" name="name" value="<%= oldData ? oldData.name : '' %>" required>
    </div>
    
    <div>
        <label>Email</label>
        <input type="email" name="email" value="<%= oldData ? oldData.email : '' %>" required>
    </div>

    <div>
        <label>Password</label>
        <input type="password" name="password" value="<%= oldData ? oldData.password : '' %>" required>
    </div>

    <button type="submit">
        Register
    </button>
</form>