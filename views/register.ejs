<h1>Recruiter Registration form</h1>

<form action="/register" method="post">

    <div>
        <label>Name</label>
        <input type="text" name="name" required>
    </div>
    
    <div>
        <label>Email</label>
        <input type="email" name="email" required>
    </div>

    <div>
        <label>Password</label>
        <input type="password" name="password" required>
    </div>

    <button type="submit">
        Register
    </button>
</form>